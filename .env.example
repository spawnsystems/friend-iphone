# ============================================================
# .env.example — copiá este archivo a .env.local y completá valores
# ============================================================

# ─── SUPABASE — expuestos al browser (publishable) ────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...

# ─── SOLO SERVIDOR — NUNCA exponer al browser ─────────────────
# Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── URL pública de la app ────────────────────────────────────
# Usada para construir redirectTo de invitaciones / password reset.
# Dev:  http://localhost:3000
# Prod: https://tu-dominio.com   (sin barra final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Bootstrap del primer platform admin ──────────────────────
# Email del usuario que se marca is_platform_admin=true al correr el seed.
SUPERADMIN_EMAIL=tu@email.com

# ─── DRIZZLE ORM — conexión directa a Postgres ────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#   → Transaction pooler (port 6543)   ← usar este
# Formato: postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
